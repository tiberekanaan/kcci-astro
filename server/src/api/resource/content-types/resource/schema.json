{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "Downloadable documents, external links, and videos."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Document",
        "Link",
        "Video"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "regulations",
        "internal",
        "external"
      ],
      "default": "internal",
      "required": true
    },
    "file": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files"
      ]
    },
    "externalLink": {
      "type": "string"
    },
    "description": {
      "type": "text"
    }
  }
}
