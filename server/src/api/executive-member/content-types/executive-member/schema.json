{
  "kind": "collectionType",
  "collectionName": "executive_members",
  "info": {
    "singularName": "executive-member",
    "pluralName": "executive-members",
    "displayName": "Member",
    "description": "KCCI board of directors and executive committee members."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string"
    },
    "memberType": {
      "type": "enumeration",
      "enum": ["board", "executive"],
      "default": "executive",
      "required": true
    },
    "bio": {
      "type": "richtext"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
