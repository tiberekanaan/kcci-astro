---
import type { Block } from '../types/blocks';
import Hero from './blocks/Hero.astro';
import AboutSection from './blocks/AboutSection.astro';
import ServicesGrid from './blocks/ServicesGrid.astro';
import ToolkitGrid from './blocks/ToolkitGrid.astro';
import Cta from './blocks/Cta.astro';
import RichText from './blocks/RichText.astro';
import MembersGrid from './blocks/MembersGrid.astro';
import ResourcesList from './blocks/ResourcesList.astro';
import PressReleasesList from './blocks/PressReleasesList.astro';
import EventsList from './blocks/EventsList.astro';
import ContactSection from './blocks/ContactSection.astro';
import PartnersGrid from './blocks/PartnersGrid.astro';

interface Props {
	block: Block;
}

const { block } = Astro.props;
---

{
	(() => {
		switch (block.__component) {
			case 'blocks.hero':
				return <Hero {...block} />;
			case 'blocks.about-section':
				return <AboutSection {...block} />;
			case 'blocks.services-grid':
				return <ServicesGrid {...block} />;
			case 'blocks.toolkit-grid':
				return <ToolkitGrid {...block} />;
			case 'blocks.cta':
				return <Cta {...block} />;
			case 'blocks.rich-text':
				return <RichText {...block} />;
			case 'blocks.members-grid':
				return <MembersGrid {...block} />;
			case 'blocks.resources-list':
				return <ResourcesList {...block} />;
			case 'blocks.press-releases-list':
				return <PressReleasesList {...block} />;
			case 'blocks.events-list':
				return <EventsList {...block} />;
			case 'blocks.contact':
				return <ContactSection {...block} />;
			case 'blocks.partners-grid':
				return <PartnersGrid {...block} />;
			default:
				// Unknown block types are skipped rather than breaking the page.
				return null;
		}
	})()
}
