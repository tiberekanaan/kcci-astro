---
import { actions, isInputError } from 'astro:actions';
import type { ContactBlock } from '../../types/blocks';

type Props = ContactBlock;

const { title, phone, email, address, officeHours, mapEmbedUrl } = Astro.props;

// No-JS fallback: a plain form POST re-renders the page with the result.
// (The inline script below upgrades submission to fetch without a reload.)
const result = Astro.getActionResult(actions.contact);
const inputErrors: Record<string, string[] | undefined> =
	result?.error && isInputError(result.error) ? result.error.fields : {};
const success = result !== undefined && !result.error;
const failure = result?.error && !isInputError(result.error) ? result.error.message : null;

const nameEmailFields = [
	{ name: 'name', label: 'Name', type: 'text', autocomplete: 'name' },
	{ name: 'email', label: 'Email', type: 'email', autocomplete: 'email' },
] as const;

const details = [
	{
		key: 'address',
		label: 'Address',
		value: address,
		href: null,
		icon: 'M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0 M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6',
	},
	{
		key: 'phone',
		label: 'Phone',
		value: phone,
		href: phone ? `tel:${phone.replace(/[^+\d]/g, '')}` : null,
		icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92',
	},
	{
		key: 'email',
		label: 'Email',
		value: email,
		href: email ? `mailto:${email}` : null,
		icon: 'M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2 M22 6l-10 7L2 6',
	},
	{
		key: 'hours',
		label: 'Office Hours',
		value: officeHours,
		href: null,
		icon: 'M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20 M12 6v6l4 2',
	},
].filter((item) => item.value);

const inputClass =
	'w-full rounded-xl border border-muted bg-background px-4 py-3 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/15';
---

<section class="py-20" data-contact>
	<div class="mx-auto max-w-6xl px-6">
		{title && <h2 data-reveal class="mb-12 text-center text-3xl font-bold tracking-tight">{title}</h2>}

		<div class="grid gap-10 lg:grid-cols-5">
			<div data-reveal class="lg:col-span-3">
				<div class="rounded-2xl border border-muted bg-background p-6 shadow-sm sm:p-8">
					<h3 class="text-xl font-semibold">Send us a message</h3>
					<p class="mt-1.5 text-sm text-muted-foreground">
						Fill in the form and we will get back to you as soon as possible.
					</p>

					<p
						data-contact-success
						hidden={!success}
						class="mt-6 rounded-xl bg-primary/10 px-4 py-3 text-sm font-medium text-primary"
						role="status"
					>
						Thank you — your message has been sent. We will be in touch soon.
					</p>
					<p
						data-contact-failure
						hidden={!failure}
						class="mt-6 rounded-xl bg-red-50 px-4 py-3 text-sm font-medium text-red-700"
						role="alert"
					>
						{failure}
					</p>

					<form method="POST" action={actions.contact} data-contact-form class="mt-6 space-y-5" novalidate>
						<div class="grid gap-5 sm:grid-cols-2">
							{
								nameEmailFields.map((field) => (
									<label class="block">
										<span class="mb-1.5 block text-sm font-medium">{field.label}</span>
										<input
											type={field.type}
											name={field.name}
											autocomplete={field.autocomplete}
											required
											class={inputClass}
										/>
										<span
											data-error-for={field.name}
											hidden={!inputErrors[field.name]}
											class="mt-1.5 block text-xs font-medium text-red-600"
										>
											{inputErrors[field.name]?.[0]}
										</span>
									</label>
								))
							}
						</div>
						<label class="block">
							<span class="mb-1.5 block text-sm font-medium">Subject</span>
							<input type="text" name="subject" autocomplete="off" required class={inputClass} />
							<span
								data-error-for="subject"
								hidden={!inputErrors.subject}
								class="mt-1.5 block text-xs font-medium text-red-600"
							>
								{inputErrors.subject?.[0]}
							</span>
						</label>
						<label class="block">
							<span class="mb-1.5 block text-sm font-medium">Message</span>
							<textarea name="message" rows="6" required class={inputClass}></textarea>
							<span
								data-error-for="message"
								hidden={!inputErrors.message}
								class="mt-1.5 block text-xs font-medium text-red-600"
							>
								{inputErrors.message?.[0]}
							</span>
						</label>
						<!-- Honeypot: hidden from real users, bots tend to fill it. -->
						<label class="sr-only" aria-hidden="true">
							Leave this field empty
							<input type="text" name="website" tabindex="-1" autocomplete="off" />
						</label>
						<button
							type="submit"
							data-contact-submit
							class="group inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-neutral-900 shadow-sm transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/20 active:scale-95 disabled:pointer-events-none disabled:opacity-60"
						>
							<span data-contact-submit-label>Send Message</span>
							<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z" />
								<path d="m21.854 2.147-10.94 10.939" />
							</svg>
						</button>
					</form>
				</div>
			</div>

			<div class="space-y-8 lg:col-span-2">
				{
					details.length > 0 && (
						<ul data-reveal style="--reveal-delay: 90ms" class="space-y-5">
							{details.map((item) => (
								<li class="flex items-start gap-4">
									<span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary/10 text-primary">
										<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
											{item.icon.split(' M').map((d, i) => (
												<path d={i === 0 ? d : `M${d}`} />
											))}
										</svg>
									</span>
									<div>
										<h3 class="text-sm font-semibold">{item.label}</h3>
										{item.href ? (
											<a href={item.href} class="mt-0.5 block text-sm text-muted-foreground transition-colors hover:text-primary">
												{item.value}
											</a>
										) : (
											<p class="mt-0.5 whitespace-pre-line text-sm text-muted-foreground">{item.value}</p>
										)}
									</div>
								</li>
							))}
						</ul>
					)
				}
				{
					mapEmbedUrl && (
						<div data-reveal style="--reveal-delay: 180ms" class="overflow-hidden rounded-2xl border border-muted shadow-sm">
							<iframe
								src={mapEmbedUrl}
								title="Map showing the KCCI office location"
								class="h-72 w-full border-0 lg:h-80"
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"
								allowfullscreen
							/>
						</div>
					)
				}
			</div>
		</div>
	</div>
</section>

<script>
	import { actions, isInputError } from 'astro:actions';

	// Upgrade the form to submit via fetch, showing inline feedback in place.
	for (const root of document.querySelectorAll('[data-contact]')) {
		const form = root.querySelector<HTMLFormElement>('[data-contact-form]');
		const successBanner = root.querySelector<HTMLElement>('[data-contact-success]');
		const failureBanner = root.querySelector<HTMLElement>('[data-contact-failure]');
		const submit = root.querySelector<HTMLButtonElement>('[data-contact-submit]');
		const submitLabel = root.querySelector<HTMLElement>('[data-contact-submit-label]');
		if (!form || !successBanner || !failureBanner || !submit || !submitLabel) continue;

		const fieldErrors = [...form.querySelectorAll<HTMLElement>('[data-error-for]')];
		const clearFeedback = () => {
			successBanner.hidden = true;
			failureBanner.hidden = true;
			for (const error of fieldErrors) error.hidden = true;
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			clearFeedback();
			submit.disabled = true;
			submitLabel.textContent = 'Sending…';

			const { error } = await actions.contact(new FormData(form));

			submit.disabled = false;
			submitLabel.textContent = 'Send Message';

			if (!error) {
				form.reset();
				successBanner.hidden = false;
				successBanner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
				return;
			}

			if (isInputError(error)) {
				const fields = error.fields as Record<string, string[] | undefined>;
				for (const element of fieldErrors) {
					const messages = fields[element.dataset.errorFor ?? ''];
					if (messages?.length) {
						element.textContent = messages[0];
						element.hidden = false;
					}
				}
				return;
			}

			failureBanner.textContent = error.message;
			failureBanner.hidden = false;
		});
	}
</script>
