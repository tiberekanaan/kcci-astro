---
import type { AboutSectionBlock } from '../../types/blocks';
import { renderMarkdown } from '../../lib/markdown';

type Props = AboutSectionBlock;

const { whoWeAre, vision, mission } = Astro.props;

const whoHtml = renderMarkdown(whoWeAre);

const cards = [
	{
		title: 'Our Vision',
		body: renderMarkdown(vision),
		// Heroicons "eye" — looking ahead
		paths: [
			'M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z',
			'M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
		],
	},
	{
		title: 'Our Mission',
		body: renderMarkdown(mission),
		// Heroicons "flag" — what we set out to do
		paths: [
			'M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 21v-1.5',
		],
	},
].filter((card) => card.body);
---

<section id="about" class="relative overflow-hidden py-24">
	<!-- Soft brand-colored glows echo the hero's floating orbs -->
	<div class="pointer-events-none absolute -left-32 top-16 -z-10 h-80 w-80 rounded-full bg-primary/10 blur-3xl"></div>
	<div class="pointer-events-none absolute -right-24 bottom-0 -z-10 h-72 w-72 rounded-full bg-accent/10 blur-3xl"></div>

	<div class="mx-auto max-w-6xl px-6">
		{
			whoHtml && (
				<div class="grid gap-10 md:grid-cols-[1fr_1.6fr] md:gap-16">
					<div data-reveal>
						<h2 class="text-3xl font-bold tracking-tight md:text-4xl">
							Who{' '}
							<span class="bg-gradient-to-r from-primary to-accent-dark bg-clip-text text-transparent">
								We Are
							</span>
						</h2>
						<span class="mt-6 block h-1 w-16 rounded-full bg-gradient-to-r from-primary to-accent" />
					</div>
					<div
						data-reveal
						style="--reveal-delay: 120ms"
						class="prose prose-lg max-w-none self-center text-muted-foreground"
						set:html={whoHtml}
					/>
				</div>
			)
		}

		{
			cards.length > 0 && (
				<div class:list={['grid gap-6 md:grid-cols-2', whoHtml && 'mt-16']}>
					{cards.map((card, i) => (
						<article
							data-reveal
							style={`--reveal-delay: ${i * 110}ms`}
							class="group relative overflow-hidden rounded-2xl border border-muted bg-gradient-to-br from-sand/70 via-background to-background p-8 transition-all duration-300 hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5"
						>
							<span class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gradient-to-r from-primary to-accent transition-transform duration-300 group-hover:scale-x-100" />
							<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-primary to-primary-dark text-white shadow-lg shadow-primary/20 transition-transform duration-300 group-hover:scale-110">
								<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
									{card.paths.map((d) => (
										<path stroke-linecap="round" stroke-linejoin="round" d={d} />
									))}
								</svg>
							</div>
							<h3 class="mt-5 text-xl font-semibold">{card.title}</h3>
							<div class="prose mt-3 max-w-none text-muted-foreground" set:html={card.body} />
						</article>
					))}
				</div>
			)
		}
	</div>
</section>
