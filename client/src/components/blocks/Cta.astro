---
import type { CtaBlock } from '../../types/blocks';
import { mediaUrl } from '../../lib/strapi';

type Props = CtaBlock;

const { title, description, button, image, imagePosition } = Astro.props;

const imageUrl = mediaUrl(image?.url);
const imageLeft = imagePosition === 'left';
---

<section id="join" class="bg-sand/60 py-20">
	<div class="mx-auto grid max-w-6xl items-center gap-10 px-6 md:grid-cols-2">
		<div data-reveal class:list={['space-y-4', imageLeft && 'md:order-2']}>
			{title && <h2 class="text-3xl font-bold tracking-tight">{title}</h2>}
			{description && <p class="text-muted-foreground">{description}</p>}
			{
				button?.label && (
					<a
						href={button.url ?? '#'}
						target={button.isExternal ? '_blank' : undefined}
						rel={button.isExternal ? 'noopener noreferrer' : undefined}
						class="group inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-neutral-900 shadow-sm transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/20 active:scale-95"
					>
						{button.label}
						<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
						</svg>
					</a>
				)
			}
		</div>
		{
			imageUrl ? (
				<div
					data-reveal
					class:list={[
						'group relative aspect-[4/3] overflow-hidden rounded-2xl shadow-lg',
						imageLeft && 'md:order-1',
					]}
					style="--reveal-delay: 120ms"
				>
					<img
						src={imageUrl}
						alt={image?.alternativeText ?? ''}
						class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
					/>
				</div>
			) : (
				<div
					data-reveal
					class:list={[
						'group relative aspect-[4/3] overflow-hidden rounded-2xl shadow-lg',
						imageLeft && 'md:order-1',
					]}
					style="--reveal-delay: 120ms; background-image: linear-gradient(135deg, #6fae3d, #2f8f5b);"
					role="img"
					aria-label="KCCI members"
				>
					<div class="absolute -bottom-10 -left-10 h-40 w-40 animate-float-slow rounded-full bg-accent/30 blur-2xl" />
					<div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(255,255,255,0.18),transparent_60%)]" />
				</div>
			)
		}
	</div>
</section>
