---
import type { HeroBlock } from '../../types/blocks';
import { mediaUrl } from '../../lib/strapi';

type Props = HeroBlock;

const { title, subtitle, buttons, backgroundImage } = Astro.props;

const bgUrl = mediaUrl(backgroundImage?.url);
const buttonList = buttons ?? [];
---

<section class="relative isolate flex min-h-[calc(100svh-5rem)] items-center overflow-hidden text-white">
	{
		bgUrl ? (
			<img
				src={bgUrl}
				alt={backgroundImage?.alternativeText ?? ''}
				class="absolute inset-0 -z-20 h-full w-full object-cover"
			/>
		) : (
			<div
				class="absolute inset-0 -z-20 animate-gradient bg-[length:200%_200%]"
				style="background-image: linear-gradient(115deg, #0f5132, #1b6e6e 38%, #2f8f5b 68%, #6fae3d);"
			/>
		)
	}
	<!-- Soft depth + floating accent orbs evoke the logo's gold + green -->
	<div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_right,rgba(255,255,255,0.18),transparent_55%)]"></div>
	<div class="absolute -right-16 top-10 -z-10 h-72 w-72 animate-float rounded-full bg-accent/30 blur-3xl"></div>
	<div class="absolute -bottom-24 left-1/4 -z-10 h-64 w-64 animate-float-slow rounded-full bg-primary/40 blur-3xl"></div>

	<div class="mx-auto w-full max-w-6xl px-6 py-20">
		<div class="max-w-2xl space-y-7">
			{
				title && (
					<h1
						data-reveal
						class="text-4xl font-bold leading-[1.1] tracking-tight md:text-6xl"
						set:html={title}
					/>
				)
			}
			{
				subtitle && (
					<p data-reveal style="--reveal-delay: 80ms" class="max-w-xl text-base text-white/85 md:text-lg">
						{subtitle}
					</p>
				)
			}
			{
				buttonList.length > 0 && (
					<div data-reveal style="--reveal-delay: 160ms" class="flex flex-wrap items-center gap-4 pt-2">
						{buttonList.map((button, i) => (
							<a
								href={button.url ?? '#'}
								target={button.isExternal ? '_blank' : undefined}
								rel={button.isExternal ? 'noopener noreferrer' : undefined}
								class:list={[
									'group inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-semibold transition-all duration-300 active:scale-95',
									i === 0
										? 'bg-accent text-neutral-900 shadow-lg shadow-black/10 hover:bg-accent-dark hover:shadow-xl'
										: 'border border-white/30 bg-white/5 text-white backdrop-blur hover:bg-white/15',
								]}
							>
								{button.label}
								{i === 0 && (
									<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
									</svg>
								)}
							</a>
						))}
					</div>
				)
			}
		</div>
	</div>
</section>
