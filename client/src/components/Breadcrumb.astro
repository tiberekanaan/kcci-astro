---
// Reusable breadcrumb trail. The last item is the current page (no link).
interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-muted-foreground">
	<ol class="flex flex-wrap items-center gap-1.5">
		{
			items.map((item, i) => (
				<li class="flex items-center gap-1.5">
					{i > 0 && (
						<svg
							class="h-4 w-4 shrink-0 text-muted-foreground/60"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="m9 18 6-6-6-6" />
						</svg>
					)}
					{item.href ? (
						<a href={item.href} class="transition-colors hover:text-primary">
							{item.label}
						</a>
					) : (
						<span aria-current="page" class="font-medium text-foreground">
							{item.label}
						</span>
					)}
				</li>
			))
		}
	</ol>
</nav>
