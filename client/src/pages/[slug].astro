---
import Layout from '../layouts/Layout.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import { fetchStrapi } from '../lib/strapi';
import type { Block } from '../types/blocks';

// SSR: generic pages are composed from a Strapi `page` dynamic zone, matched by slug.
export const prerender = false;

interface Page {
	title?: string | null;
	content?: Block[] | null;
}

const { slug } = Astro.params;

// Dynamic-zone populate uses the `on` fragment syntax: a plain `*` only goes
// one level deep, which misses media nested inside repeatable components
// (e.g. partner logos). Every block type must be listed or it is omitted
// from the response.
const contentPopulate = [
	'blocks.hero',
	'blocks.about-section',
	'blocks.services-grid',
	'blocks.toolkit-grid',
	'blocks.cta',
	'blocks.rich-text',
	'blocks.members-grid',
	'blocks.resources-list',
	'blocks.press-releases-list',
	'blocks.events-list',
	'blocks.contact',
]
	.map((name) => `populate[content][on][${name}][populate]=*`)
	.concat('populate[content][on][blocks.partners-grid][populate][partners][populate]=logo')
	.join('&');

const pages = slug
	? await fetchStrapi<Page[]>(
			`/api/pages?filters[slug][$eq]=${encodeURIComponent(slug)}&${contentPopulate}`,
		)
	: null;
const page = pages?.[0];

if (!page) {
	return new Response(null, { status: 404, statusText: 'Not found' });
}

const blocks = page.content ?? [];
---

<Layout title={page.title ?? 'KCCI'}>
	{blocks.map((block) => <BlockRenderer block={block} />)}
</Layout>
