---
import Layout from '../layouts/Layout.astro';

// NOTE: Content below is hard-coded for now. These blocks are the seams
// where editable Strapi components will plug in later (hero, about,
// services, advisor CTA, etc.).

const nav = [
	{ label: 'About Us', href: '#about' },
	{ label: 'What We Do', href: '#what-we-do' },
	{ label: 'Membership', href: '#join' },
	{ label: 'Resources', href: '#strengthen' },
	{ label: 'Contact', href: '#contact' },
];

const about = [
	{
		title: 'Who We Are',
		body: 'We are a membership-based organisation representing the private sector. Our members include retailers, wholesalers, manufacturers and service providers from every stage of the value chain across the economy.',
	},
	{
		title: 'Our Vision',
		body: 'A vibrant and dynamic private sector in which businesses of every size are competitive, resilient and well placed to seize new opportunities and drive sustainable, inclusive growth.',
	},
	{
		title: 'Our Mission',
		body: 'To foster a fair, prosperous and competitive environment for our members by advocating for sound policy, building capacity, and connecting businesses with the finance, markets and partners they need to thrive.',
	},
];

const services = [
	{
		number: '01',
		title: 'Access To Finance',
		body: 'We connect members to lenders, grants and investment partners, and help prepare the documentation needed to secure funding.',
		links: ['Loan Facilitation', 'Grant Matching', 'Investor Readiness'],
	},
	{
		number: '02',
		title: 'Capacity Building',
		body: 'Practical training, mentorship and workshops that strengthen the skills and systems businesses need to grow.',
		links: ['Workshops & Training', 'Mentorship', 'Business Clinics'],
	},
	{
		number: '03',
		title: 'Business Support',
		body: 'Advisory services, market linkages and advocacy that remove barriers and open doors for our members.',
		links: ['Advisory Services', 'Market Linkages', 'Policy Advocacy'],
	},
];

const tools = [
	{
		title: 'Health Check',
		body: 'Assess the overall health of your business across finance, operations and strategy.',
		icon: 'heart',
	},
	{
		title: 'Diagnostic Tool',
		body: 'Pinpoint gaps and opportunities with a guided self-assessment.',
		icon: 'chart',
	},
	{
		title: 'Climate Action Centre',
		body: 'Build a more sustainable, climate-resilient business model.',
		icon: 'leaf',
	},
	{
		title: 'Continuity Planner',
		body: 'Prepare for disruption with a tailored business continuity plan.',
		icon: 'shield',
	},
	{
		title: 'Business Growth',
		body: 'Map a clear path to scale with growth planning resources.',
		icon: 'trend',
	},
];
---

<Layout title="KCCI · Grow Your Business With Us">
	<!-- Header -->
	<header class="sticky top-0 z-50 border-b border-muted bg-background/80 backdrop-blur-md">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
			<a href="/" class="group flex items-center gap-2.5 font-bold tracking-tight">
				<span
					class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-primary to-accent text-sm text-white shadow-sm transition-transform duration-300 group-hover:scale-105 group-hover:rotate-3"
				>
					K
				</span>
				<span>KCCI <span class="text-primary">Business Link</span></span>
			</a>
			<nav class="hidden items-center gap-7 text-sm font-medium text-muted-foreground md:flex">
				{nav.map((item) => (
					<a
						href={item.href}
						class="relative transition-colors hover:text-primary after:absolute after:-bottom-1.5 after:left-0 after:h-0.5 after:w-0 after:rounded-full after:bg-accent after:transition-all after:duration-300 hover:after:w-full"
					>
						{item.label}
					</a>
				))}
			</nav>
			<a
				href="#join"
				class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white shadow-sm transition-all duration-300 hover:bg-primary-dark hover:shadow-md hover:shadow-primary/20 active:scale-95"
			>
				Join
			</a>
		</div>
	</header>

	<!-- Hero -->
	<section class="relative isolate overflow-hidden text-white">
		<!-- Animated brand gradient base -->
		<div
			class="absolute inset-0 -z-20 animate-gradient bg-[length:200%_200%]"
			style="background-image: linear-gradient(115deg, #0f5132, #1b6e6e 38%, #2f8f5b 68%, #6fae3d);"
		>
		</div>
		<!-- Soft depth + floating accent orbs evoke the logo's gold + green -->
		<div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_right,rgba(255,255,255,0.18),transparent_55%)]"></div>
		<div class="absolute -right-16 top-10 -z-10 h-72 w-72 animate-float rounded-full bg-accent/30 blur-3xl"></div>
		<div class="absolute -bottom-24 left-1/4 -z-10 h-64 w-64 animate-float-slow rounded-full bg-primary/40 blur-3xl"></div>

		<div class="mx-auto max-w-6xl px-6 py-28 md:py-36">
			<div class="max-w-2xl space-y-7">
				<span
					data-reveal
					class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-4 py-1.5 text-xs font-medium tracking-wide text-white/90 backdrop-blur"
				>
					<span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
					Kiribati Chamber of Commerce &amp; Industry
				</span>
				<h1 data-reveal style="--reveal-delay: 80ms" class="text-4xl font-bold leading-[1.1] tracking-tight md:text-6xl">
					Grow Your Business <span class="text-gradient">With Us</span>
				</h1>
				<p data-reveal style="--reveal-delay: 160ms" class="max-w-xl text-base text-white/85 md:text-lg">
					Join a community of businesses with access to finance, training and
					advisory support designed to help you compete, grow and thrive.
				</p>
				<div data-reveal style="--reveal-delay: 240ms" class="flex flex-wrap items-center gap-4 pt-2">
					<a
						href="#join"
						class="group inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-neutral-900 shadow-lg shadow-black/10 transition-all duration-300 hover:bg-accent-dark hover:shadow-xl active:scale-95"
					>
						Join Us
						<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
						</svg>
					</a>
					<a
						href="#what-we-do"
						class="inline-flex items-center rounded-lg border border-white/30 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition-all duration-300 hover:bg-white/15 active:scale-95"
					>
						What We Do
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Who We Are / Vision / Mission -->
	<section id="about" class="mx-auto max-w-5xl px-6 py-20">
		<div class="divide-y divide-muted">
			{about.map((row, i) => (
				<div data-reveal style={`--reveal-delay: ${i * 90}ms`} class="group grid gap-4 py-8 md:grid-cols-3 md:gap-10">
					<h2 class="flex items-center gap-3 text-xl font-semibold">
						<span class="h-5 w-1 rounded-full bg-gradient-to-b from-primary to-accent transition-all duration-300 group-hover:h-7"></span>
						{row.title}
					</h2>
					<p class="text-muted-foreground md:col-span-2">{row.body}</p>
				</div>
			))}
		</div>
	</section>

	<!-- What We Do -->
	<section id="what-we-do" class="bg-sand/60 py-20">
		<div class="mx-auto max-w-6xl px-6">
			<h2 data-reveal class="mb-12 text-center text-3xl font-bold tracking-tight">What We Do</h2>
			<div class="grid gap-6 md:grid-cols-3">
				{services.map((service, i) => (
					<article
						data-reveal
						style={`--reveal-delay: ${i * 110}ms`}
						class="group relative flex flex-col overflow-hidden rounded-2xl border border-muted bg-background p-6 transition-all duration-300 hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5"
					>
						<span class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gradient-to-r from-primary to-accent transition-transform duration-300 group-hover:scale-x-100"></span>
						<span class="bg-gradient-to-br from-primary to-accent bg-clip-text text-4xl font-bold text-transparent">{service.number}</span>
						<h3 class="mt-4 text-lg font-semibold">{service.title}</h3>
						<p class="mt-2 flex-1 text-sm text-muted-foreground">{service.body}</p>
						<ul class="mt-4 space-y-2 border-t border-muted pt-4 text-sm font-medium text-primary">
							{service.links.map((link) => (
								<li class="flex items-center gap-2">
									<span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
									{link}
								</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- Strengthen Your Business -->
	<section id="strengthen" class="mx-auto max-w-6xl px-6 py-20 text-center">
		<h2 data-reveal class="text-3xl font-bold tracking-tight">Strengthen Your Business</h2>
		<p data-reveal style="--reveal-delay: 80ms" class="mx-auto mt-3 max-w-2xl text-muted-foreground">
			A suite of free tools to help you assess, plan and build a stronger,
			more resilient business.
		</p>
		<div class="mt-12 grid gap-6 text-left sm:grid-cols-2 lg:grid-cols-3">
			{tools.map((tool, i) => (
				<div
					data-reveal
					style={`--reveal-delay: ${i * 80}ms`}
					class="group flex gap-4 rounded-2xl border border-muted bg-background p-5 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-lg hover:shadow-accent/5"
				>
					<span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-gradient-to-br from-primary/10 to-accent/15 text-primary transition-all duration-300 group-hover:from-primary group-hover:to-accent group-hover:text-white">
						<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							{tool.icon === 'heart' && <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />}
							{tool.icon === 'chart' && <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />}
							{tool.icon === 'leaf' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />}
							{tool.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />}
							{tool.icon === 'trend' && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.307a11.95 11.95 0 0 1 5.814-5.519l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />}
						</svg>
					</span>
					<div>
						<h3 class="font-semibold">{tool.title}</h3>
						<p class="mt-1 text-sm text-muted-foreground">{tool.body}</p>
					</div>
				</div>
			))}
		</div>
		<a
			data-reveal
			href="#join"
			class="group mt-10 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all duration-300 hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/20 active:scale-95"
		>
			Get Started
			<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
			</svg>
		</a>
	</section>

	<!-- Find an Advisor -->
	<section class="bg-sand/60 py-20">
		<div class="mx-auto grid max-w-6xl items-center gap-10 px-6 md:grid-cols-2">
			<div
				data-reveal
				class="group relative aspect-[4/3] overflow-hidden rounded-2xl shadow-lg"
				style="background-image: linear-gradient(135deg, #2f8f5b, #1b6e6e);"
				role="img"
				aria-label="Business advisors meeting with members"
			>
				<div class="absolute -right-10 -top-10 h-40 w-40 animate-float rounded-full bg-accent/30 blur-2xl"></div>
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.15),transparent_60%)]"></div>
			</div>
			<div data-reveal style="--reveal-delay: 120ms" class="space-y-4">
				<h2 class="text-3xl font-bold tracking-tight">Find A BLP Business Advisor</h2>
				<p class="text-muted-foreground">
					Our network of experienced advisors offer one-on-one guidance tailored
					to your business. Book a session and get practical, actionable advice.
				</p>
				<a
					href="#contact"
					class="group inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all duration-300 hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/20 active:scale-95"
				>
					Book an Advisor
					<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
					</svg>
				</a>
			</div>
		</div>
	</section>

	<!-- Ready To Join -->
	<section id="join" class="mx-auto max-w-6xl px-6 py-20">
		<div class="grid items-center gap-10 md:grid-cols-2">
			<div data-reveal class="space-y-4">
				<h2 class="text-3xl font-bold tracking-tight">Ready To Join?</h2>
				<p class="text-muted-foreground">
					Become a member today and unlock access to finance, training, advisory
					services and a community of businesses growing together.
				</p>
				<a
					href="#contact"
					class="group inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-neutral-900 shadow-sm transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/20 active:scale-95"
				>
					Become a Member
					<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
					</svg>
				</a>
			</div>
			<div
				data-reveal
				class="group relative aspect-[4/3] overflow-hidden rounded-2xl shadow-lg"
				style="--reveal-delay: 120ms; background-image: linear-gradient(135deg, #6fae3d, #2f8f5b);"
				role="img"
				aria-label="KCCI members"
			>
				<div class="absolute -bottom-10 -left-10 h-40 w-40 animate-float-slow rounded-full bg-accent/30 blur-2xl"></div>
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(255,255,255,0.18),transparent_60%)]"></div>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer id="contact" class="bg-neutral-900 text-neutral-300">
		<div class="mx-auto grid max-w-6xl gap-10 px-6 py-14 sm:grid-cols-2 md:grid-cols-4">
			<div class="space-y-3">
				<div class="flex items-center gap-2.5 font-bold text-white">
					<span class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-primary to-accent text-sm shadow-sm">K</span>
					<span>KCCI Business Link</span>
				</div>
				<p class="text-sm text-neutral-400">
					Representing and empowering the private sector to compete, grow and thrive.
				</p>
			</div>
			<div>
				<h3 class="mb-3 text-sm font-semibold text-white">About Us</h3>
				<ul class="space-y-2 text-sm text-neutral-400">
					<li><a href="#about" class="transition-colors hover:text-accent">Who We Are</a></li>
					<li><a href="#about" class="transition-colors hover:text-accent">Our Vision</a></li>
					<li><a href="#what-we-do" class="transition-colors hover:text-accent">What We Do</a></li>
				</ul>
			</div>
			<div>
				<h3 class="mb-3 text-sm font-semibold text-white">Membership</h3>
				<ul class="space-y-2 text-sm text-neutral-400">
					<li><a href="#join" class="transition-colors hover:text-accent">Become a Member</a></li>
					<li><a href="#strengthen" class="transition-colors hover:text-accent">Member Tools</a></li>
					<li><a href="#contact" class="transition-colors hover:text-accent">Find an Advisor</a></li>
				</ul>
			</div>
			<div>
				<h3 class="mb-3 text-sm font-semibold text-white">External Links</h3>
				<ul class="space-y-2 text-sm text-neutral-400">
					<li><a href="#" class="transition-colors hover:text-accent">Ministry of Commerce</a></li>
					<li><a href="#" class="transition-colors hover:text-accent">Investment Board</a></li>
					<li><a href="#" class="transition-colors hover:text-accent">Business Registry</a></li>
				</ul>
			</div>
		</div>
		<div class="border-t border-neutral-800 py-6 text-center text-xs text-neutral-500">
			© {new Date().getFullYear()} KCCI Business Link. All rights reserved.
		</div>
	</footer>

	<!-- Progressive scroll-reveal: lift + fade elements in as they appear. -->
	<script>
		const reveals = document.querySelectorAll('[data-reveal]');
		if ('IntersectionObserver' in window) {
			const io = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							io.unobserve(entry.target);
						}
					}
				},
				{ threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
			);
			reveals.forEach((el) => io.observe(el));
		} else {
			reveals.forEach((el) => el.classList.add('is-visible'));
		}
	</script>
</Layout>
