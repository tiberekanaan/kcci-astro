---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { fetchStrapi, mediaUrl } from '../lib/strapi';
import type { GlobalData } from '../types/blocks';

interface Props {
	title?: string;
}

const { title = 'KCCI' } = Astro.props;

// Site-wide nav/footer come from the `global` Single Type so editors can
// manage them in Strapi. Falls back to null (sensible defaults) if Strapi
// is unreachable.
const global = await fetchStrapi<GlobalData>('/api/global?populate=*');

// Editor-uploaded favicon wins; the static /favicon.svg is the fallback.
const faviconUrl = mediaUrl(global?.favicon?.url);
const faviconType = faviconUrl?.endsWith('.svg') ? 'image/svg+xml' : undefined;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		{
			faviconUrl ? (
				<link rel="icon" type={faviconType} href={faviconUrl} />
			) : (
				<>
					<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
					<link rel="icon" href="/favicon.ico" />
				</>
			)
		}
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-background text-foreground font-sans">
		<Header siteName={global?.siteName} logo={global?.logo} navLinks={global?.navLinks} />
		<slot />
		<Footer siteName={global?.siteName} footerLinks={global?.footerLinks} />
	</body>
</html>
