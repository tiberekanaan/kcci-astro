---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { fetchStrapi } from '../lib/strapi';
import type { GlobalData } from '../types/blocks';

interface Props {
	title?: string;
}

const { title = 'KCCI' } = Astro.props;

// Site-wide nav/footer come from the `global` Single Type so editors can
// manage them in Strapi. Falls back to null (sensible defaults) if Strapi
// is unreachable.
const global = await fetchStrapi<GlobalData>('/api/global?populate=*');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-background text-foreground font-sans">
		<Header siteName={global?.siteName} navLinks={global?.navLinks} />
		<slot />
		<Footer siteName={global?.siteName} footerLinks={global?.footerLinks} />
	</body>
</html>
