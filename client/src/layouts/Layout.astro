---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { fetchStrapi, mediaUrl } from '../lib/strapi';
import type { GlobalData } from '../types/blocks';

interface Props {
	title?: string;
}

const { title = 'KCCI' } = Astro.props;

// Site-wide nav/footer come from the `global` Single Type so editors can
// manage them in Strapi. Falls back to null (sensible defaults) if Strapi
// is unreachable.
const global = await fetchStrapi<GlobalData>(
	'/api/global?populate[logo]=true&populate[favicon]=true&populate[footerLinks]=true&populate[footerLogo]=true&populate[navLinks][populate]=links',
);

// Editor-uploaded favicon wins; the static /favicon.svg is the fallback.
const faviconUrl = mediaUrl(global?.favicon?.url);
const faviconType = faviconUrl?.endsWith('.svg') ? 'image/svg+xml' : undefined;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		{
			faviconUrl ? (
				<link rel="icon" type={faviconType} href={faviconUrl} />
			) : (
				<>
					<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
					<link rel="icon" href="/favicon.ico" />
				</>
			)
		}
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-background text-foreground font-sans flex min-h-screen flex-col">
		<Header siteName={global?.siteName} logo={global?.logo} navLinks={global?.navLinks} />
		<div class="flex-1">
			<slot />
		</div>
		<Footer
			siteName={global?.siteName}
			footerLinks={global?.footerLinks}
			footerLogo={global?.footerLogo}
			footerAttribution={global?.footerAttribution}
		/>

		<!-- Progressive scroll-reveal: lift + fade [data-reveal] elements in as
		     they appear. Lives in the shared layout so every page gets it. -->
		<script>
			const reveals = document.querySelectorAll('[data-reveal]');
			if ('IntersectionObserver' in window) {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								io.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
				);
				reveals.forEach((el) => io.observe(el));
			} else {
				reveals.forEach((el) => el.classList.add('is-visible'));
			}
		</script>
	</body>
</html>
